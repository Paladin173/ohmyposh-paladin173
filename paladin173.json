{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "right",
      "newline": true,
      "segments": [
        {
          "foreground": "#e4e4e4",
          "options": {
            "style": "austin",
            "always_enabled": true
          },
          "style": "plain",
          "template": "{{ .FormattedMs }} ",
          "type": "executiontime"
        },
        {
          "foreground": "#d75f00",
          "style": "plain",
          "template": "| {{ .Shell }} on ",
          "type": "shell"
        },
        {
          "foreground": "#d75f00",
          "options": {
            "windows": "\ue62a Win",
            "ubuntu": "\uf31b Ubuntu",
            "debian": "\uf306 Debian",
            "linux": "\ue712 Linux",
            "macos": "\uf179 macOS",
            "alpine": "\uf300 Alpine",
            "arch": "\uf303 Arch",
            "centos": "\uf304 CentOS",
            "elementary": "\uf309 Elementary",
            "fedora": "\uf30a Fedora",
            "gentoo": "\uf30d Gentoo",
            "manjaro": "\uf312 Manjaro",
            "mint": "\uf30f Mint",
            "opensuse": "\uf314 openSUSE",
            "raspbian": "\uf315 Raspbian"
          },
          "style": "plain",
          "template": "{{ .Icon }} | ",
          "type": "os"
        },
        {
          "foreground": "#0087af",
          "style": "plain",
          "template": "\ue266 {{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB ({{ printf \"%.0f\" .PhysicalPercentUsed }}%) ",
          "type": "sysinfo"
        },
        {
          "foreground": "#a8a8a8",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": "| {{ .CurrentDate | date .Format }} ",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#61afef",
          "style": "plain",
          "template": "\u256d\u2500 {{ if or (env \"WSL_DISTRO_NAME\") (env \"container\") }}{{ .Location }}{{ else }}{{ .Location | replace \"/\" \"\\\\\" }}{{ end }}",
          "options": {
            "style": "full"
          },
          "type": "path"
        },
        {
          "foreground": "#378504",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#a97400{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#54433a{{ end }}",
            "{{ if gt .Ahead 0 }}#744d89{{ end }}",
            "{{ if gt .Behind 0 }}#744d89{{ end }}"
          ],
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "branch_icon": "git: ",
            "branch_identical_icon": "=",
            "branch_gone_icon": "gone"
          },
          "style": "plain",
          "template": " [ {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} | ~ {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} | + {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} | stash: {{ .StashCount }}{{ end }} ]",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#61afef",
          "style": "plain",
          "template": "\u2570\u2500 {{ if .Root }}#{{else}}>{{end}}",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
