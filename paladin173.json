{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "right",
      "newline": true,
      "segments": [
        {
          "foreground": "#e4e4e4",
          "options": {
            "style": "austin",
            "always_enabled": true
          },
          "style": "plain",
          "template": "{{ .FormattedMs }} | ",
          "type": "executiontime"
        },
        {
          "foreground": "#0087af",
          "style": "plain",
          "template": "RAM: {{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB ({{ printf \"%.0f\" .PhysicalPercentUsed }}%) | ",
          "type": "sysinfo"
        },
        {
          "foreground": "#d75f00",
          "options": {
            "time_format": "15:04:05 CST"
          },
          "style": "plain",
          "template": "{{ .CurrentDate | date .Format }} ",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#d75f00",
          "options": {
            "alpine": "Alpine",
            "arch": "Arch",
            "centos": "CentOS",
            "debian": "Debian",
            "elementary": "Elementary",
            "fedora": "Fedora",
            "gentoo": "Gentoo",
            "linux": "Linux",
            "macos": "macOS",
            "manjaro": "Manjaro",
            "mint": "Mint",
            "opensuse": "openSUSE",
            "raspbian": "Raspbian",
            "ubuntu": "Ubuntu",
            "windows": "Win"
          },
          "style": "plain",
          "template": "\u256d\u2500[ {{ .Icon }} ]",
          "type": "os"
        },
        {
          "foreground": "#e4e4e4",
          "options": {
            "style": "full"
          },
          "style": "plain",
          "template": " {{ .Location | replace \"/\" \"\\\\\" }}",
          "type": "path"
        },
        {
          "foreground": "#378504",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#a97400{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#54433a{{ end }}",
            "{{ if gt .Ahead 0 }}#744d89{{ end }}",
            "{{ if gt .Behind 0 }}#744d89{{ end }}"
          ],
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "branch_icon": "git: ",
            "branch_identical_icon": "=",
            "branch_gone_icon": "gone"
          },
          "style": "plain",
          "template": " [ {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} | ~ {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} | + {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} | stash: {{ .StashCount }}{{ end }} ]",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#d75f00",
          "style": "plain",
          "template": "\u2570\u2500 {{ if .Root }}#{{else}}${{end}}",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
